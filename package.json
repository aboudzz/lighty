{
    "name": "lighty",
    "version": "0.0.1",
    "description": "lighty RESTful Stateless API boilerplate",
    "main": "app.js",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "mongo:deploy": "docker run -d -p 27017:27017 --name=mongo -v mongo_data:/data/db -v mongo_config:/data/configdb mongo:latest",
        "mongo:start": "docker start mongo",
        "mongo:stop": "docker stop mongo",
        "mongo:rm": "docker rm -f -v mongo",
        "mailserver:up": "MAILSERVER_FQDN=${MAILSERVER_FQDN:-mail.lighty.com} docker compose -f ./mailserver/compose.yml up -d",
        "mailserver:setup": "./mailserver/setup.sh email add info@lighty.com $MAIL_SENDER_PASSWORD",
        "mailserver:down": "docker compose -f ./mailserver/compose.yml down",
        "start": "node ./bin/www",
        "generate:openapi": "node ./bin/generate-openapi.js",
        "start:development": "run-script-os",
        "start:development:win32": "set DEBUG=debug:*&& nodemon ./bin/www",
        "start:development:darwin:linux": "DEBUG=debug:* nodemon ./bin/www",
        "start:production": "run-script-os",
        "start:production:win32": "set NODE_ENV=production && pm2 -o logs/out.log -e logs/err.log start ./bin/www",
        "start:production:darwin:linux": "NODE_ENV=production pm2 -o logs/out.log -e logs/err.log start ./bin/www",
        "stop:production": "pm2 stop ./bin/www",
        "lint": "eslint .",
        "test": "npx jest --coverage --testResultsProcessor jest-sonar-reporter"
    },
    "jestSonar": {
        "reportPath": "coverage",
        "reportFile": "sonar-report.xml",
        "indent": 4
    },
    "author": "Aboud Zakaria",
    "license": "ISC",
    "repository": {
        "type": "git",
        "url": "git://github.com/aboudzz/lighty.git"
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "config": "^4.4.1",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "ejs": "^4.0.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.2",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.2.3",
        "nanoid": "^5.1.7",
        "nodemailer": "^8.0.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "validator": "^13.15.26"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.0.2",
        "globals": "^17.4.0",
        "jest": "^30.2.0",
        "jest-sonar-reporter": "^2.0.0",
        "js-yaml": "^4.1.0",
        "nodemon": "^3.1.0",
        "pino-pretty": "^13.1.3",
        "run-script-os": "^1.1.6",
        "sonar-scanner": "^3.1.0",
        "supertest": "^7.2.2",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1"
    }
}
