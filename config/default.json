{
    "server": {
        "host": "localhost",
        "port": "3000"
    },
    "mongodb": {
        "uri": "mongodb://localhost:27017/lighty"
    },
    "mail": {
        "service": "localhost",
        "port": 587,
        "secure": false,
        "sender": "info@lighty.com",
        "sender_password_env": "MAIL_SENDER_PASSWORD"
    },
    "admin": {
        "email": "admin@lighty.com",
        "password_env": "ADMIN_PASSWORD"
    },
    "jwt": {
        "secret_env": "JWT_SECRET",
        "expiresIn": "24h"
    },
    "cors": {
        "origins": ["http://localhost:3000", "http://localhost:3001"]
    },
    "rateLimit": {
        "windowMs": 600000,
        "max": 100
    },
    "app": {
        "url": "http://localhost:3000"
    },
    "datetime": {
        "format": "ddd mmm dd yyyy HH:MM:ss.l"
    },
    "swagger": {
        "generate": true,
        "path": "./lighty-openapi.yml",
        "options": {
            "failOnErrors": true,
            "definition": {
                "openapi": "3.0.0",
                "info": {
                    "title": "lighty",
                    "version": "0.0.1",
                    "description": "lighty RESTful Stateless API boilerplate documentation"
                }
            },
            "apis": [
                "./resources/swagger/*.yml",
                "./models/*.js",
                "./routes/*.js"
            ]
        }
    }
}
