# Server Configuration
NODE_ENV=development
HOST=localhost
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/lighty

# JWT Configuration (REQUIRED - minimum 32 characters recommended)
# Generate with: openssl rand -base64 32
JWT_SECRET=

# Mail Server Configuration (REQUIRED for email functionality)
MAIL_SERVICE=mail.lighty.com
MAIL_SENDER=info@lighty.com
MAIL_PASSWORD=

# Admin User Configuration (REQUIRED for admin user creation)
ADMIN_EMAIL=admin@lighty.com
ADMIN_PASSWORD=

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX_REQUESTS=100

# Application URL (for email links)
APP_URL=http://localhost:3000
